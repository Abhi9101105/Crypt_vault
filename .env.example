# ============================================
# CryptVault — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# General
# ──────────────────────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=production  # ← set this on Render

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# SQLite (local development)
DATABASE_URL=sqlite:///./securevault.db
# PostgreSQL (production on Render — use Internal Database URL)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ──────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_char_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14

# ──────────────────────────────────────────────
# Encryption (AES-256-GCM)
# ──────────────────────────────────────────────
# Generate: python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEYS=v1:CHANGE_ME_base64_encoded_32_byte_key
ACTIVE_KEY_ID=v1

# ──────────────────────────────────────────────
# Audit HMAC
# ──────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AUDIT_HMAC_SECRET=CHANGE_ME_generate_a_random_secret

# ──────────────────────────────────────────────
# Storage
# ──────────────────────────────────────────────
STORAGE_DIR=vault
MAX_UPLOAD_BYTES=26214400

# ──────────────────────────────────────────────
# CORS (comma-separated)
# ──────────────────────────────────────────────
# Local development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production (replace with your Vercel URL)
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ──────────────────────────────────────────────
# Server (Render sets PORT automatically)
# ──────────────────────────────────────────────
# PORT=8000
LOG_LEVEL=INFO
