# ============================================
# CryptVault — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./securevault.db

# JWT Authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_char_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14

# Encryption Keyring (AES-256-GCM)
# Generate with: python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEYS=v1:CHANGE_ME_base64_encoded_32_byte_key
ACTIVE_KEY_ID=v1

# Audit HMAC
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AUDIT_HMAC_SECRET=CHANGE_ME_generate_a_random_secret

# Storage
STORAGE_DIR=vault
MAX_UPLOAD_BYTES=26214400

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development
